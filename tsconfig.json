{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* Paths & Architecture */
    "paths": {
      "@pages/*": ["./pages/*"],
      "@tests/*": ["./tests/*"],
      "@api/*": ["./api/*"],
      "@dataprovider/*": ["./dataprovider/*"]
    },

    /* Strictness & Safety */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Interop & Isolation */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "pages/**/*",
    "api/**/*",
    "dataprovider/**/*",
    "playwright.config.ts"
  ]
}
