{
  "flow": "Authentication",
  "description": "Login and logout flows",
  "login": {
    "steps": [
      {
        "step": 1,
        "action": "Navigate to BASE_URL",
        "result": "Landing page loads (unauthenticated state)"
      },
      { "step": 2, "action": "Click 'Login' button in nav", "result": "Navigates to /login" },
      {
        "step": 3,
        "action": "Fill Email Address input with process.env.USER_NAME",
        "locator": "getByRole('textbox', { name: 'Email Address' })"
      },
      {
        "step": 4,
        "action": "Fill Password input with process.env.PASSWORD",
        "locator": "getByRole('textbox', { name: 'Password' })"
      },
      {
        "step": 5,
        "action": "Click Login button",
        "locator": "page.locator('form').getByRole('button', { name: 'Login' })"
      },
      {
        "step": 6,
        "action": "Wait for 'My Orders' button visible",
        "locator": "getByRole('button', { name: 'My Orders' })",
        "result": "Authenticated — redirected to /"
      }
    ],
    "successMarker": { "role": "button", "name": "My Orders" },
    "failureMarker": { "text": "Invalid email or password." },
    "credentials": { "email": "process.env.USER_NAME", "password": "process.env.PASSWORD" }
  },
  "logout": {
    "steps": [
      {
        "step": 1,
        "action": "Click 'Logout' button in nav",
        "locator": "getByRole('button', { name: 'Logout' })",
        "result": "Redirects to /"
      },
      {
        "step": 2,
        "action": "Verify Login button visible",
        "locator": "getByRole('button', { name: 'Login' })",
        "result": "Unauthenticated state confirmed"
      }
    ]
  },
  "storageState": {
    "file": ".auth/user.json",
    "savedBy": "tests/auth.setup.ts",
    "usedBy": "playwright.config.ts — applied globally to all browser projects",
    "note": "Do not add test.use(storageState) unless test must run WITHOUT auth"
  }
}
